{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2015",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "./dist",
    "rootDir": "./",
    "lib": ["ES2015", "ES2016", "ES2017", "DOM"],
    "removeComments": false,
    "esModuleInterop": true
  },
  "include": ["main.ts"],
  "exclude": ["node_modules", "dist"]
}